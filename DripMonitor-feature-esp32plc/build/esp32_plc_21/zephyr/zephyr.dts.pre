&flash0 {
 partitions {
  compatible = "fixed-partitions";
  #address-cells = <1>;
  #size-cells = <1>;

  boot_partition: partition@1000 {
   label = "mcuboot";
   reg = <0x1000 ((60) * 1024)>;
  };

  sys_partition: partition@10000 {
   label = "sys";
   reg = <0x10000 ((64) * 1024)>;
  };

  slot0_partition: partition@20000 {
   label = "image-0";
   reg = <0x20000 ((7936) * 1024)>;
  };

  slot1_partition: partition@7e0000 {
   label = "image-1";
   reg = <0x7e0000 ((7936) * 1024)>;
  };

  slot0_lpcore_partition: partition@fa0000 {
   label = "image-0-lpcore";
   reg = <0xfa0000 ((32) * 1024)>;
  };

  slot1_lpcore_partition: partition@fa8000 {
   label = "image-1-lpcore";
   reg = <0xfa8000 ((32) * 1024)>;
  };

  storage_partition: partition@fb0000 {
   label = "storage";
   reg = <0xfb0000 ((192) * 1024)>;
  };

  scratch_partition: partition@fe0000 {
   label = "image-scratch";
   reg = <0xfe0000 ((124) * 1024)>;
  };

  coredump_partition: partition@fff000 {
   label = "coredump";
   reg = <0xfff000 ((4) * 1024)>;
  };
 };
};
# 38 "C:/Projects/DripMonitor-feature-esp32plc/DripMonitor-feature-esp32plc/boards/industrialshields/esp32_plc_21/esp32_plc_21_esp32_procpu.dts" 2

/ {
 model = "Industrial Shields ESP32 PLC 21 V3 (PROCPU)";
 compatible = "industrialshields,esp32-plc-21", "espressif,esp32";

 chosen {
  zephyr,sram = &sram1;
  zephyr,console = &uart0;
  zephyr,shell-uart = &uart0;
  zephyr,flash = &flash0;
  zephyr,code-partition = &slot0_partition;
  zephyr,uart-mcumgr = &uart0;
 };

 aliases {
  watchdog0 = &wdt0;
  modbus0 = &modbus_rs485;
  uart-0 = &uart0;
  uart-485 = &uart2;
  i2c-0 = &i2c0;
  rtc = &ds3231;
  eth0 = &eth_w5500;
  sdhc0 = &sd_slot;
 };
};

&uart0 {
 status = "okay";
 current-speed = <115200>;
 pinctrl-0 = <&uart0_default>;
 pinctrl-names = "default";
};
# 81 "C:/Projects/DripMonitor-feature-esp32plc/DripMonitor-feature-esp32plc/boards/industrialshields/esp32_plc_21/esp32_plc_21_esp32_procpu.dts"
&uart2 {
 status = "okay";
 current-speed = <19200>;
 pinctrl-0 = <&uart2_default>;
 pinctrl-names = "default";

 modbus_rs485: modbus_rs485 {
  compatible = "zephyr,modbus-serial";
  status = "okay";
  de-gpios = <&gpio0 4 (0 << 0)>;
 };
};

&gpio0 {
 status = "okay";
};

&gpio1 {
 status = "okay";
};

&i2c0 {
 status = "okay";
 clock-frequency = <100000>;
 sda-gpios = <&gpio0 21 ((1 << 1) | (1 << 2))>;
 scl-gpios = <&gpio0 22 ((1 << 1) | (1 << 2))>;
 pinctrl-0 = <&i2c0_default>;
 pinctrl-names = "default";

 mcp23008: gpio@21 {
  compatible = "microchip,mcp23008";
  reg = <0x21>;
  gpio-controller;
  #gpio-cells = <2>;
  ngpios = <8>;
  status = "okay";
 };

 ads1015_48: adc@48 {
  compatible = "ti,ads1015";
  reg = <0x48>;
  #io-channel-cells = <1>;
  #address-cells = <1>;
  #size-cells = <0>;
  status = "okay";
 };

 ads1015_49: adc@49 {
  compatible = "ti,ads1015";
  reg = <0x49>;
  #io-channel-cells = <1>;
  #address-cells = <1>;
  #size-cells = <0>;
  status = "okay";
 };

 pca9685: pwm@40 {
  compatible = "nxp,pca9685-pwm";
  reg = <0x40>;
  #pwm-cells = <3>;
  status = "okay";
 };

 ds3231_mfd: ds3231@68 {
  compatible = "maxim,ds3231-mfd";
  reg = <0x68>;
  status = "okay";

  ds3231: ds3231-rtc {
   compatible = "maxim,ds3231-rtc";
   status = "okay";
# 160 "C:/Projects/DripMonitor-feature-esp32plc/DripMonitor-feature-esp32plc/boards/industrialshields/esp32_plc_21/esp32_plc_21_esp32_procpu.dts"
   isw-gpios = <&gpio1 2 (1 << 0)>;
  };
 };
};

&spi3 {
 #address-cells = <1>;
 #size-cells = <0>;
 status = "okay";
 pinctrl-0 = <&spim3_default>;
 pinctrl-names = "default";

 cs-gpios = <&gpio0 15 (1 << 0)>,
     <&gpio0 13 (1 << 0)>;

 eth_w5500: eth@0 {
  compatible = "wiznet,w5500";
  reg = <0x0>;
  spi-max-frequency = <(((20) * 1000) * 1000)>;



  int-gpios = <&gpio1 2 (1 << 0)>;
  status = "okay";
 };

 sd_slot: sdhc@1 {
  compatible = "zephyr,sdhc-spi-slot";
  reg = <1>;
  spi-max-frequency = <(((20) * 1000) * 1000)>;
  status = "okay";

  mmc {
   compatible = "zephyr,sdmmc-disk";
   disk-name = "SD";
   status = "okay";
  };
 };
};

&trng0 {
 status = "okay";
};

&wdt0 {
 status = "okay";
};






&wifi {
 status = "disabled";
};

&esp32_bt_hci {
 status = "disabled";
};
