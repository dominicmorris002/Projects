   clocks = <&clock 109>;
   status = "disabled";
  };

  ledc0: ledc@3ff59000 {
   compatible = "espressif,esp32-ledc";
   #pwm-cells = <3>;
   reg = <0x3ff59000 0x800>;
   clocks = <&clock 100>;
