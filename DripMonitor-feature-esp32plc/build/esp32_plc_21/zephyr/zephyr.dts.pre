/ {
 aliases {
  inp-drip = &inp_drip;
  inp-mtr-run = &inp_mtr_run;
  inp-low-oil = &inp_low_oil;

  out-led-grn = &out_led_grn;
  out-led-red = &out_led_red;
  out-mtr-enable = &out_mtr_enable;
  out-pump-spd = &out_pump_spd;
 };

 inputs {
  compatible = "gpio-keys";

  inp_drip: inp_drip {
   gpios = <&gpio0 27 (0 << 0)>;
   label = "I0.5 (Drip)";
  };
  inp_mtr_run: inp_mtr_run {
   gpios = <&mcp23008 4 (0 << 0)>;
   label = "I0.1 (Motor Run)";
  };
  inp_low_oil: inp_low_oil {
   gpios = <&mcp23008 6 (0 << 0)>;
   label = "I0.0 (Low Oil)";
  };
 };
# 92 "C:/Projects/DripMonitor-feature-esp32plc/DripMonitor-feature-esp32plc/boards/esp32_plc_21_esp32_procpu.overlay"
 pwmdevs {
  compatible = "pwm-leds";

  out_led_grn: out_led_grn {
   pwms = <&pca9685 11 ((625) * 1000UL) (0 << 0)>;
   label = "LED Green (Q0.0)";
  };
  out_led_red: out_led_red {
   pwms = <&pca9685 10 ((625) * 1000UL) (0 << 0)>;
   label = "LED Red (Q0.1)";
  };
  out_mtr_enable: out_mtr_enable {
   pwms = <&pca9685 9 ((625) * 1000UL) (0 << 0)>;
   label = "Motor Enable (Q0.2)";
  };
  out_pump_spd: out_pump_spd {
   pwms = <&pca9685 13 ((625) * 1000UL) (0 << 0)>;
   label = "Pump Speed (Q0.5, analog out 1)";
  };
 };
};

&i2c0 {
 lcd: lcd@28 {
  compatible = "i2c-device";
  reg = <0x28>;
  label = "LK204 LCD";
 };
};
