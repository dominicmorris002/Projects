source "subsys/logging/Kconfig.template.log_config"

module = APP_DISPLAY
module-str = app_display
source "subsys/logging/Kconfig.template.log_config"

module = APP_CLOUD
module-str = app_cloud
source "subsys/logging/Kconfig.template.log_config"

endmenu

source "Kconfig.zephyr"